# 后端 API Base URL（Laravel 那个）
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# 站点名称（可选，用在 <title> 等位置）
NEXT_PUBLIC_APP_NAME=Gentlegurl Shop

# 主题颜色: 1 = Soft Pink & Cream, 2 = FEFBE8 + F0DFD5
NEXT_PUBLIC_COLOR=2

# Ecommerce 站点 base URL（用于从 Booking 跳回商城）
# 例: https://xxxx.com
NEXT_PUBLIC_ECOMMERCE_BASE_URL=http://localhost:3001

