# Backend API base URL
NEXT_PUBLIC_API_BASE_URL=https://api.gentlegurls.com

# Booking site URL (change to your final domain if needed)
NEXT_PUBLIC_SITE_URL=https://gentlegurls.com/booking

# Site name shown in metadata
NEXT_PUBLIC_APP_NAME=GentleGurls Booking

# Theme color mode
NEXT_PUBLIC_COLOR=1

# Timezone for booking UI
NEXT_PUBLIC_TIMEZONE=Asia/Kuala_Lumpur

# Docker-watch labels
WATCH_ENABLE=true
WATCH_NAME=booking-shop
